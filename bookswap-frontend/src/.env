# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api
VITE_APP_NAME=BookSwap
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_CHAT=true

# Google Books API (optional)s
# Other Configuration
VITE_MAX_UPLOAD_SIZE=5
VITE_SUPPORTED_IMAGE_FORMATS=jpeg,png,jpg,webp